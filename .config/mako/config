background-color=#1a1b2661
text-color=#a9b1d6
border-color=#7aa2f7
border-size=3
border-radius=15
font=JetBrainsMono Nerd Font 14
padding=15,30,15,30
margin=10
width=280
height=60
text-alignment=center
progress-color=over #7aa2f79E

# === 核心行为配置 ===
default-timeout=15000
ignore-timeout=1
group-by=app-name
on-button-left=dismiss
max-visible=5
icons=1
max-icon-size=48

[app-name=wp-vol]
layer=overlay
history=0
anchor=top-center
group-by=app-name
format=<b>%s</b>\n%b

[urgency=low]
invisible=1
