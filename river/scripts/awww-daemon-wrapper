#!/bin/sh

DAEMON=/usr/bin/awww-daemon
CHECK_INTERVAL=5
MAX_RETRIES=3

while true; do
    "$DAEMON"
    EXIT_CODE=$?

    if [ $EXIT_CODE -eq 0 ]; then
        exit 0
    fi

    RETRIES=$((RETRIES + 1))
    if [ $RETRIES -ge $MAX_RETRIES ]; then
        sleep 10
    else
        sleep 1
    fi
done